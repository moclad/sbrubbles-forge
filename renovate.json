{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":separateMajorReleases",
    ":prHourlyLimitNone",
    ":prConcurrentLimit10"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 5am on monday"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": false,
    "schedule": ["before 5am on monday"]
  },
  "ignoreDeps": ["actions/upload-artifact"],
  "packageRules": [
    {
      "description": "Group minor JavaScript updates to reduce CI load",
      "matchManagers": ["pnpm"],
      "matchUpdateTypes": ["minor"],
      "groupName": "all minor npm dependencies",
      "automerge": false
    },
    {
      "description": "Automerge patch updates after CI checks pass",
      "matchManagers": ["pnpm"],
      "matchUpdateTypes": ["patch"],
      "groupName": "all patch pnpm dependencies",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Keep major updates separate for manual review",
      "matchManagers": ["pnpm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "Stagger Playwright and Next updates because they may require test fixes",
      "matchPackageNames": ["playwright", "@playwright/test", "next"],
      "groupName": "framework-and-e2e-core",
      "automerge": false
    }
  ]
}
