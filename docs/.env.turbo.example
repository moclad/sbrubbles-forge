# Turborepo Remote Cache Configuration
# Copy this file to .env.turbo.local and customize

# Cache Server URL
TURBO_API=http://localhost:3001

# Security Token (must match TURBO_TOKEN in docker-compose)
TURBO_TOKEN=dev-secret-change-me

# Team/Project Name (optional)
TURBO_TEAM=sbrubbles-forge

# Storage Provider (local, s3, gcs, azure)
STORAGE_PROVIDER=local

# S3 Configuration (if using S3/R2/Minio)
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=turbo-cache
# S3_REGION=us-east-1
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Logging
LOG_LEVEL=info
