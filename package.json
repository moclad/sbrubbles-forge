{
  "name": "sbrubbles-forge",
  "version": "4.1.20",
  "private": true,
  "bin": {
    "sbrubbles-forge": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "e2e": "turbo e2e",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "lint": "ultracite lint",
    "test": "turbo test",
    "analyze": "turbo analyze",
    "boundaries": "turbo boundaries",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design-system",
    "db:migrate": "cd packages/database && npx drizzle-kit migrate",
    "db:generate": "cd packages/database && npx drizzle-kit generate",
    "db:pull": "cd packages/database && npx drizzle-kit pull",
    "db:push": "cd packages/database && npx drizzle-kit push",
    "studio": "cd packages/database && pnpm dev",
    "release:ci": "release-it --ci",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:next-version": "release-it --ci --release-version | tail -n1",
    "clean": "git clean -xdf node_modules",
    "changeset": "changeset",
    "release": "changeset publish",
    "services:start": "docker compose -f docker-compose.yml -f ./docker-compose-storage.yml up -d --remove-orphans"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@changesets/cli": "^2.30.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "2.9.4",
    "@types/node": "catalog:",
    "import-in-the-middle": "^3.0.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "release-it-pnpm": "^4.6.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "turbo": "^2.9.4",
    "typescript": "catalog:",
    "ultracite": "7.3.2",
    "vitest": "catalog:test"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@sentry/cli",
      "@swc/core",
      "@tailwindcss/oxide",
      "bufferutil",
      "core-js-pure",
      "esbuild",
      "sharp"
    ]
  },
  "repository": "sbrubbles-work/sbrubbles-forge",
  "author": "Beno Dresch <sbrubbles@sbrubbles.work>"
}
